{
  "manifest_version": 3,
  "name": "Eestify",
  "version": "1.0",
  "description": "Learn Estonian naturally with difficulty levels, categories, quizzes, audio, grammar hints, achievements, and more.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://lingva.ml/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Open Eestify popup"
    },
    "toggle-extension": {
      "suggested_key": {
        "default": "Alt+E"
      },
      "description": "Toggle Eestify on/off"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dictionary.js", "content.js"]
    }
  ]
}